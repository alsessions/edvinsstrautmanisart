{
  "require": {
    "craftcms/ckeditor": "^3.8.3",
    "craftcms/cms": "^4.0",
    "craftcms/contact-form": "^3.1.0",
    "craftcms/contact-form-honeypot": "^2.1",
    "craftcms/feed-me": "^5.5.0",
    "hybridinteractive/craft-contact-form-extensions": "^4.2.2",
    "mmikkel/cp-clearcache": "^1.3.1",
    "nystudio107/craft-imageoptimize": "^4.0.8",
    "nystudio107/craft-seomatic": "^4.0.49",
    "solspace/craft-freeform": "^5.9.15",
    "verbb/expanded-singles": "^2.0.5",
    "verbb/formie": "^2.1",
    "vlucas/phpdotenv": "^3.4.0"
  },
  "autoload": {
    "psr-4": {
      "modules\\": "modules/"
    }
  },
    "config": {
        "allow-plugins": {
            "craftcms/plugin-installer": true,
            "yiisoft/yii2-composer": true
        },
        "sort-packages": true,
        "optimize-autoloader": true,
        "audit": {
            "block-insecure": false
        },
        "platform": {
      "php": "8.3.0"
    }
    },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ]
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://composer.craftcms.com",
      "canonical": false
    }
  ]
}
