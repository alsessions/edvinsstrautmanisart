{% include '/partials/_head.twig' %}

<body>

	{% include '/partials/_nav-dark.twig' %}
	<main class="container  max-w-7xl px-4 mx-auto">
		<section class="prose prose-lg prose-headings:font-normal prose-headings:text-gray-400 max-w-none mx-auto">
			<h1 class="mt-20">{{ entry.title }}</h1>

			<div class="grid md:grid-cols-2 gap-12 prose prose-lg max-w-none">
				{% for block in entry.pageContent.all() %}
					<div>
						{% switch block.type %}

							{% case "text" %}
								{{ block.text }}
								{# Redactor #}
							</div>
							<div>

								{% case "image" %}

									{% set optimizedImages = block.image.one().optimizedImages %}
									<picture>
										<source srcset="{{ optimizedImages.srcsetWebP() }}" sizes="100vw" type="image/webp"/>
										<img src="{{ optimizedImages.src() }}" srcset="{{ optimizedImages.srcset() }}" sizes="100vw" class="my-4 p-6 rounded-md" alt="Page image"/>
									</picture>

								</div>
							</div>

							{% default %}
							...

						{% endswitch %}
					{% endfor %}

				</section>

				<section class=" mt-12 prose prose-lg max-w-none">

					<h2 class="text-gray-800 text-2xl my-10 font-light">Cesis Art Festival &mdash; 2019</h2>

					<img src="/assets/cesis_gallery_wid-croppede.jpg" class="mb-4 w-full rounded">

					<p>In July 2019,
						<strong>The National Art Museum of
							Latvia</strong>
						organized the Close-Up Exhibition in
						Cesis, Latvia.</p>
					<p>This first-ever retrospective
						of Edvins Strautmanis in his native country
						showcases a scope of work never before
						shown, and depicts the most significant and
						creative period of the artists’ career</p>

					<p>
						<a href="/work/cesis" class="text-blue-600">View Gallery</a>
					</p>

				</section>
				<div class="grid md:grid-cols-2 gap-12">
					<section class="md:my-12 content">
						<h2 class="text-gray-800 text-2xl mt-10 mb-2">Exhibitions &amp; Collections</h2>
						<div class="tab w-full overflow-hidden border-t">
							<input class="absolute opacity-0" id="tab-single-one" type="radio" name="tabs2">
							<label class="block py-3 text-gray-600 text-lg leading-normal font-medium cursor-pointer" for="tab-single-one">Solo Exhibitions</label>
							<div class="tab-content overflow-hidden  leading-normal pl-4">
								<p>1996- Staller Center for the Arts, Stony Brook, NY</p>
								<p>1994- Stephen Rosenburg Gallery, NYC</p>
								<p>1994- Kunst-Museum, Ahlen, Germany</p>
								<p>1992- Jahnhorst and Preuss, Berlin, Germany</p>
								<p>1991- Stephen Rosenburg Gallery, NYC</p>
								<p>1991- Galerie Metta Linde, Lubeck, Germany</p>
								<p>1990- Stephen Rosenberg Gallery, NYC</p>
								<p>1987- OK Harris Gallery, NYC</p>
								<p>1987- Galerie Sylvia Menzel, Berlin, Germany</p>
								<p>1987- Galerie Brigitta Jacob, Oldenburg, Germany</p>
								<p>1987- United States Mission, Berlin, Germany</p>
								<p>1986- John Guggenheim Gallery, Miami, Fl</p>
								<p>1986- Benson gallery, Southampton, NY</p>
								<p>1985- Bockley Gallery, Minneapolis, MN</p>
								<p>1984- Reynold C. Kerr Gallery, NYC</p>
								<p>1984- Jeremy Stone Gallery, San Francisco, CA</p>
								<p>1983- The Grayson Gallery, Chicago, IL</p>
								<p>1982- Allan Stone Gallery, NYC</p>
								<p>1980- Allan Stone Gallery, NYC</p>
								<p>1979- Samuel Stein Fine Arts, Chicago, IL</p>
								<p>1979- Walter Kelly Gallery, Chicago, IL</p>
								<p>1977- Allan Stone Gallery, NYC</p>
								<p>1975- Allan Stone Gallery, NYC</p>
								<p>1974- Isis Gallery, Notre Dame University, IN</p>
								<p>1973- Walter Kelly Gallery, Chicago, IL</p>
								<p>1973- LoGiudice Gallery, NYC</p>
								<p>1970- LoGiudice Gallery, NYC</p>
								<p>1965- University of Chicago, IL</p>
							</div>
						</div>
						<div class="tab w-full overflow-hidden border-t">
							<input class="absolute opacity-0" id="tab-single-two" type="radio" name="tabs2">
							<label class="block py-3 text-gray-600 font-medium text-lg leading-normal cursor-pointer" for="tab-single-two">Group Exhibitions</label>
							<div class="tab-content overflow-hidden  leading-normal pl-4">
								<p>2002- Abstraction, Allan Stone Gallery, New York, NY</p>
								<p>1997- One of A Kind, Rosenberg + Kaufman Gallery, New York, NY</p>
								<p>1995- Rigas Galeriga, Riga, Latvia</p>
								<p>1993- The Tenth Summer, Stephen Rosenberg Gallery, New York, NY</p>
								<p>1993- Jahnhorst and Preuss, Berlin, Germany</p>
								<p>1991- Paper Trail, Stephen Rosenberg Gallery, New York, NY</p>
								<p>1990- The Art Studio, New York, NY</p>
								<p>1989- Anita Shapolsky Gallery, New York, NY</p>
								<p>1988- Noordkunst, Groningen Museum, Denmark</p>
								<p>1987- Kouros Gallery, New York, NY</p>
								<p>1986- Benton Gallery, Southampton, NY</p>
								<p>1985- Five New York Expressionists, Newton Arts Center, Newton, MA</p>
								<p>1985- Advanced Abstraction, Burke Gallery, New York, NY</p>
								<p>1983- Swen Parson Gallery, Northern Illinois University, De Kalb, IL</p>
								<p>1983-Stephen Rosenberg Gallery, New York, NY</p>
								<p>1978- Abstract Expressionism and Its Disciples, Allan Stone Gallery, New York, NY</p>
